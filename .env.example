# RAM_ISTP — environment template. Copy to `.env` and fill in; NEVER commit real
# secrets. The binary reads these via std::env (export them, or use your shell's
# dotenv). Signals-only: none of these enable order placement.

# --- Data archive ---------------------------------------------------------
# Absolute path to the parquet root ({tf}/{SYMBOL}.parquet). Defaults to the
# bundled ./1500-Stocks-Parquest if unset.
RAM_ISTP_DATA_ROOT=

# --- DuckDB memory safety (18GB box) -------------------------------------
# Per-connection DuckDB memory cap; past it, queries spill to disk instead of
# OOM-crashing. Default "2GB" (bounds aggregate ≈ cores × cap under 18GB).
RAM_ISTP_DB_MEMORY_LIMIT=2GB

# --- Live universe --------------------------------------------------------
# Max NSE-equity instrument_tokens to subscribe on the live WebSocket
# (Kite caps ~3000/connection). Default 1600.
RAM_ISTP_LIVE_UNIVERSE_MAX=1600

# --- News sentiment (OFF by default; on-demand for the Top-10 only) -------
# Provider: "mock" (default, no network), "marketaux", or "eodhd".
# Indian-news scoping is applied per provider (Marketaux: &countries=in
# &exchanges=NSE; EODHD: the .NSE symbol suffix).
NEWS_PROVIDER=mock
# Your provider API key. Leave blank for mock. NEVER commit a real key.
NEWS_API_KEY=

# --- Zerodha Kite (ONLY needed for the live WebSocket feed; see SESSION_HANDOVER) ---
# The instruments dump (`ram_istp instruments`) is PUBLIC and needs none of these.
# These are for the authenticated live tick feed (Phase 5), not yet wired in.
# Re-auth each morning; the token expires ~6 AM IST next day.
KITE_API_KEY=
KITE_ACCESS_TOKEN=
